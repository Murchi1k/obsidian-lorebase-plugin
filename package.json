{
    "name": "lorebase",
    "version": "2.0.5",
    "description": "A media hub for games, anime, movies, series, books, and manga with rich cards, progress, ratings, and metadata.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "node esbuild.config.mjs production",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "keywords": [
        "obsidian",
        "plugin",
        "games",
        "anime",
        "movies",
        "books",
        "library"
    ],
    "author": "Murch1k",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.10.0",
        "esbuild": "^0.28.0",
        "obsidian": "1.11.4",
        "tslib": "^2.8.1",
        "typescript": "^5.3.2",
        "vitest": "^4.0.18"
    }
}
