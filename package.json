{
    "name": "lorebase",
    "version": "1.0.0",
    "description": "Track games and anime in Obsidian with card views, status filters, ratings, and metadata integrations",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "node esbuild.config.mjs production",
